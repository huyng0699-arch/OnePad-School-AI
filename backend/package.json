{
  "name": "onepad-real-backend",
  "version": "0.2.0",
  "private": true,
  "type": "commonjs",
  "description": "OnePad School AI backend app: student event pipeline, role-based reports, admin dashboard.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && npm run prisma:seed",
    "reset": "npx prisma migrate reset --force && npm run prisma:seed",
    "test:pipeline": "powershell -ExecutionPolicy Bypass -File scripts/test-pipeline.ps1",
    "test:health": "ts-node scripts/test-health-wellbeing.ts",
    "test:trends": "ts-node scripts/test-student-trends.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
